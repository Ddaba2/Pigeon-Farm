{
  "name": "pigeon-farm-mobile",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Gestion d'élevage de pigeons - Application mobile hors ligne pour les fermiers maliens",
  "scripts": {
    "postinstall": "node scripts/copy-wasm.cjs",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "android:add": "npx cap add android",
    "android:sync": "npm run build && npx cap sync android",
    "android:open": "npx cap open android",
    "android:run": "npm run android:sync && npx cap run android",
    "apk": "npm run android:sync && npx cap open android"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^6.0.2",
    "@capacitor/android": "^6.2.0",
    "@capacitor/app": "^6.0.2",
    "@capacitor/core": "^6.2.0",
    "@capacitor/filesystem": "^6.0.4",
    "@capacitor/local-notifications": "^6.1.3",
    "@capacitor/network": "^6.0.2",
    "@capacitor/share": "^6.0.4",
    "@capacitor/splash-screen": "^6.0.3",
    "@capacitor/status-bar": "^6.0.2",
    "jeep-sqlite": "^2.7.8",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "jimp": "^1.6.1",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.4",
    "vite": "^5.3.4"
  }
}
